CRASHLYTICS_DATA_SOURCE=mock
GOOGLE_APPLICATION_CREDENTIALS=./secrets/sa.json
BIGQUERY_PROJECT_ID=
CRASHLYTICS_DATASET=firebase_crashlytics
APPS=ios_main,ios_beta
APP_IOS_MAIN_TABLE=com.example.app_IOS
APP_IOS_BETA_TABLE=com.example.beta_IOS
APP_IOS_MAIN_GITHUB_REPO=myorg/ios-app
APP_IOS_BETA_GITHUB_REPO=myorg/ios-beta
APP_IOS_MAIN_FIREBASE_PROJECT=
APP_IOS_BETA_FIREBASE_PROJECT=
DIGEST_WEBHOOK_URL=
DIGEST_TOP_N=10
DIGEST_CRON=0 9 * * *
PORT=3001

# Phase 2 — LLM (DIRECT mode)
OPENAI_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
LLM_EXPLORER=google:gemini-2.0-flash
LLM_SYNTHESIS=openai:gpt-4o
RCA_MAX_BUDGET_USD=0.50

# Optional GATEWAY mode
LLM_GATEWAY_BASE_URL=
LLM_GATEWAY_API_KEY=

# Phase 3 — PRD gap review
PRDS=playback-redesign,onboarding-v2
PRD_MAX_BUDGET_USD=0.30
ATLASSIAN_MCP_ENABLED=false
# ATLASSIAN_MCP_COMMAND=
# ATLASSIAN_MCP_ARGS=

# Postgres (local Homebrew — no Docker)
# brew install postgresql@17 && brew services start postgresql@17
# createdb agenttrain
# Use your macOS username; Homebrew Postgres often has no password locally.
DATABASE_URL=postgresql://YOUR_MAC_USERNAME@localhost:5432/agenttrain

# GitHub (read-only)
GITHUB_TOKEN=

# Firebase MCP (opt-in — avoids npx/npm warnings; uses mock tools when unset)
# Install: pnpm --filter @agent-train/agents add firebase-tools
FIREBASE_MCP_ENABLED=false
# FIREBASE_MCP_COMMAND=/absolute/path/to/firebase
# FIREBASE_MCP_ARGS=mcp

# Serena MCP (optional — mock explorer fallback if unset)
SERENA_MCP_COMMAND=
SERENA_MCP_ARGS=
SERENA_REPO_PATH=
