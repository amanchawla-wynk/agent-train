{
  "name": "@agent-train/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "digest:run": "tsx src/cli/digest.ts",
    "db:migrate": "tsx src/db/migrate.ts"
  },
  "dependencies": {
    "@agent-train/agents": "workspace:*",
    "@agent-train/shared": "workspace:*",
    "@google-cloud/bigquery": "^7.9.4",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "node-cron": "^3.0.3",
    "pg": "^8.16.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.18",
    "@types/express": "^5.0.2",
    "@types/node": "^22.15.21",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.15.2",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "supertest": "^7.1.1",
    "vitest": "^3.2.4"
  }
}
