{
  "name": "@agent-train/agents",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc && cp -r src/skills dist/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "eval:rca": "tsx src/eval/eval-runner.ts",
    "eval:prd": "tsx src/eval/prd-eval-runner.ts"
  },
  "dependencies": {
    "@agent-train/shared": "workspace:*",
    "@ai-sdk/google": "^2.0.23",
    "@ai-sdk/mcp": "^1.0.46",
    "@ai-sdk/openai": "^2.0.106",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@octokit/rest": "^21.1.1",
    "ai": "^5.0.196",
    "zod": "^3.25.76"
  },
  "optionalDependencies": {
    "firebase-tools": "^14.12.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
